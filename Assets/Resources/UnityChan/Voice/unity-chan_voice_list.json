    },
    {
      "id": "univ0037",
      "text": "あなたも一緒に遊ぼうよ！",
      "duration": 1.881
    },
    {
      "id": "univ0038",
      "text": "あなたも一緒に　どうかな？",
      "duration": 2.024
    },
    {
      "id": "univ0039",
      "text": "あなたの夢、一緒にかなえようよ",
      "duration": 2.647
    },
    {
      "id": "univ0040",
      "text": "あなたの夢、一緒にかなえよう",
      "duration": 2.438
    },
    {
      "id": "univ0041",
      "text": "はじめまして。わたし《ユニティちゃん》",
      "duration": 2.81
    },
    {
      "id": "univ0042",
      "text": "夢は、わたしだけの遊び場を作ること",
      "duration": 3.135
    },
    {
      "id": "univ0043",
      "text": "空いてる倉庫がひとつあるんだ。自由に使っていいよって！　なんかワクワクしない？",
      "duration": 5.991
    },
    {
      "id": "univ0044",
      "text": "空いてる倉庫があるんだ。自由に使っていいよって！　ワクワクしない？",
      "duration": 5.12
    },
    {
      "id": "univ0045",
      "text": "ユニティちゃん",
      "duration": 1.219
    },
    {
      "id": "univ1000",
      "text": "おはよっ！　今日も元気にがんばっていこーっ！",
      "duration": 3.401
    },
    {
      "id": "univ1001",
      "text": "こんにちは！　お昼はもう食べたのかなっ！？　午後も頑張っていくとしますかっ！",
      "duration": 5.541
    },
    {
      "id": "univ1002",
      "text": "こんばんは！　今日ももうすぐ終わりだねっ！　何かいいことあったかなっ？　明日も頑張っていこうねっ！",
      "duration": 7.637
    },
    {
      "id": "univ1003",
      "text": "そんじゃ、始めるとしますか！",
      "duration": 2.387
    },
    {
      "id": "univ1004",
      "text": "ユニティちゃんオフィシャルページへようこそ！",
      "duration": 2.441
    },
    {
      "id": "univ1005",
      "text": "ここはユニティちゃんオフィシャルページ。わたしのお部屋にようこそ！",
      "duration": 4.436
    },
    {
      "id": "univ1006",
      "text": "わたしのオフィシャルページにようこそ。ゆっくりしていってね…えへへっ！",
      "duration": 4.618
    },
    {
      "id": "univ1007",
      "text": "アート＆デザインのコーナーだよっ！",
      "duration": 2.285
    },
    {
      "id": "univ1008",
      "text": "データダウンロードのコーナーだよっ！",
      "duration": 2.269
    },
    {
      "id": "univ1009",
      "text": "ユニティちゃんブログだよっ！",
      "duration": 1.805
    },
    {
      "id": "univ1010",
      "text": "さてさて…最新情報はあるかなっ！？",
      "duration": 3.218
    },
    {
      "id": "univ1011",
      "text": "わたしとの約束だよっ！　ちゃんと読んでねっ！",
      "duration": 3.303
    },
    {
      "id": "univ1012",
      "text": "あらら…更新はなかったみたい。ごめんねぇ〜っ！",
      "duration": 3.968
    },
    {
      "id": "univ1013",
      "text": "また一緒に遊ぼうねっ！　バイバイーっ！",
      "duration": 2.89
    },
    {
      "id": "univ1014",
      "text": "えーっ！　もう行っちゃうのーっ！？",
      "duration": 2.423
    },
    {
      "id": "univ1015",
      "text": "えー…おほん（咳払いのアドリブ）　アーユーレディ？",
      "duration": 3.538
    },
    {
      "id": "univ1016",
      "text": "スタートっ！",
      "duration": 0.981
    },
    {
      "id": "univ1017",
      "text": "ゴーーーールッ！",
      "duration": 1.298
    },
    {
      "id": "univ1018",
      "text": "クリアっ！　やったねっ！",
      "duration": 1.96
    },
    {
      "id": "univ1019",
      "text": "オールクリアっ！　おめでとうっ！",
      "duration": 2.57
    },
    {
      "id": "univ1020",
      "text": "エクセレントっ！　すっごーいっ！",
      "duration": 2.546
    },
    {
      "id": "univ1021",
      "text": "がんばれーっ！",
      "duration": 1.345
    },
    {
      "id": "univ1022",
      "text": "（可愛らしく）ファイトぉっ！",
      "duration": 1.187
    },
    {
      "id": "univ1023",
      "text": "おーえす、おーえす！　ゴーッ！",
      "duration": 3.141
    },
    {
      "id": "univ1024",
      "text": "どんまいっ！",
      "duration": 1.08
    },
    {
      "id": "univ1025",
      "text": "あらら…残念っ！",
      "duration": 1.939
    },
    {
      "id": "univ1026",
      "text": "もう一回やってみる？",
      "duration": 1.653
    },
    {
      "id": "univ1027",
      "text": "そうこなくっちゃねっ！",
      "duration": 1.499
    },
    {
      "id": "univ1028",
      "text": "（明るく）お疲れ様っ！",
      "duration": 1.213
    },
    {
      "id": "univ1029",
      "text": "おっけーっ！",
      "duration": 1.13
    },
    {
      "id": "univ1030",
      "text": "のぉーっ！",
      "duration": 1.157
    },
    {
      "id": "univ1031",
      "text": "のん、のん",
      "duration": 1.203
    },
    {
      "id": "univ1032",
      "text": "ぽちっと！",
      "duration": 1.093
    },
    {
      "id": "univ1033",
      "text": "（いたずらっぽく）チェック、するっ？",
      "duration": 1.506
    },
    {
      "id": "univ1034",
      "text": "ロード中だよっ。もう少しだけ待っててねっ！",
      "duration": 3.059
    },
    {
      "id": "univ1035",
      "text": "（可愛らしく）いやーんっ！",
      "duration": 1.083
    },
    {
      "id": "univ1036",
      "text": "（可愛らしく）もう…ばかぁ…",
      "duration": 1.95
    },
    {
      "id": "univ1037",
      "text": "（可愛らしく）ああん…そんなことしちゃダメだってー",
      "duration": 3.294
    },
    {
      "id": "univ1038",
      "text": "（軽く驚いた感じで）きゃっ！",
      "duration": 0.611
    },
    {
      "id": "univ1039",
      "text": "（不思議そうに）ふぇっ？",
      "duration": 0.771
    },
    {
      "id": "univ1040",
      "text": "ねぇねぇ…今なにしてるのかなっ！？",
      "duration": 2.572
    },
    {
      "id": "univ1041",
      "text": "来たなぁ〜っ！　ユニティ仮面っ！",
      "duration": 2.525
    },
    {
      "id": "univ1042",
      "text": "ユニティ仮面！　勝負っ！",
      "duration": 2.132
    },
    {
      "id": "univ1043",
      "text": "さすがね。ユニティ仮面…",
      "duration": 2.186
    },
    {
      "id": "univ1044",
      "text": "やったあっ！　ユニティ仮面に勝っちゃった！",
      "duration": 3.314
    },
    {
      "id": "univ1045",
      "text": "引き分けよっ！　ユニティ仮面！",
      "duration": 2.258
    },
    {
      "id": "univ1046",
      "text": "ユニティ仮面…もしかして、あなたは…",
      "duration": 4.186
    },
    {
      "id": "univ1047",
      "text": "またね…ユニティ仮面",
      "duration": 1.884
    },
    {
      "id": "univ1048",
      "text": "ナイスファイトっ！",
      "duration": 1.302
    },
    {
      "id": "univ1049",
      "text": "わたしと一緒にユニティを覚えちゃおうっ！",
      "duration": 2.875
    },
    {
      "id": "univ1050",
      "text": "わたしと一緒にパーティを組もうっ！",
      "duration": 2.317
    },
    {
      "id": "univ1051",
      "text": "ユニティ県人会議へようこそっ！",
      "duration": 2.387
    },
    {
      "id": "univ1052",
      "text": "あなたが、伝説の支援Ｐ（ぴー）？",
      "duration": 2.427
    },
    {
      "id": "univ1053",
      "text": "イベント、もりだくさんっ！",
      "duration": 1.858
    },
    {
      "id": "univ1054",
      "text": "イベント情報だよっ！",
      "duration": 1.57
    },
    {
      "id": "univ1055",
      "text": "会場で待ってるよっ！　みんな遊びにきてねっ！",
      "duration": 3.807
    },
    {
      "id": "univ1056",
      "text": "なにそれっ！？　もしかして、強いのっ！？",
      "duration": 3.154
    },
    {
      "id": "univ1057",
      "text": "ふむふむ…なかなかいいところを突いてくるねぇ…",
      "duration": 4.13
    },
    {
      "id": "univ1058",
      "text": "こんなこともあろうかと思ってぇ！　とりゃあっ！",
      "duration": 3.434
    },
    {
      "id": "univ1059",
      "text": "（不敵に）ふっふーん…いいたいことはそれだけっ！？",
      "duration": 3.529
    },
    {
      "id": "univ1060",
      "text": "お・し・お・き…しちゃおっかなーっ！？",
      "duration": 3.639
    },
    {
      "id": "univ1061",
      "text": "ご・ほ・う・び…あげちゃおっかなーっ！？",
      "duration": 3.614
    },
    {
      "id": "univ1062",
      "text": "そ・れ・は…秘密、だよっ！",
      "duration": 3.686
    },
    {
      "id": "univ1063",
      "text": "異議ありっ！",
      "duration": 0.863
    },
    {
      "id": "univ1064",
      "text": "異議なしっ！",
      "duration": 0.954
    },
    {
      "id": "univ1065",
      "text": "ギルティっ！",
      "duration": 0.917
    },
    {
      "id": "univ1066",
      "text": "ノット・ギルティっ！",
      "duration": 1.652
    },
    {
      "id": "univ1067",
      "text": "ロード中にイジェクトボタンを押しちゃだめぇ〜っ！",
      "duration": 3.148
    },
    {
      "id": "univ1068",
      "text": "（感心するように）ほほぉ……ふぅむ……へぇぇ…",
      "duration": 5.788
    },
    {
      "id": "univ1069",
      "text": "プレゼント、あげるっ！",
      "duration": 1.495
    },
    {
      "id": "univ1070",
      "text": "アイテム、ゲット！",
      "duration": 1.484
    },
    {
      "id": "univ1071",
      "text": "回復、してあげるっ！",
      "duration": 1.599
    },
    {
      "id": "univ1072",
      "text": "オーケィ、わたしにまかせてっ！",
      "duration": 2.777
    },
    {
      "id": "univ1073",
      "text": "サンクス！",
      "duration": 0.961
    },
    {
      "id": "univ1074",
      "text": "ナイス、フォロー！",
      "duration": 1.256
    },
    {
      "id": "univ1075",
      "text": "ここはあなたにまかせるわ",
      "duration": 2.001
    },
    {
      "id": "univ1076",
      "text": "いよいよボスの登場ね…",
      "duration": 2.243
    },
    {
      "id": "univ1077",
      "text": "（悔しそうに）くっ…ここまで来たのに…",
      "duration": 2.859
    },
    {
      "id": "univ1078",
      "text": "倍返しよっ！",
      "duration": 1.353
    },
    {
      "id": "univ1079",
      "text": "（あくびのブレスの後で）…ねまーしゅ〜",
      "duration": 4.145
    },
    {
      "id": "univ1080",
      "text": "このゲームはユニティちゃんライセンスで提供されています",
      "duration": 3.788
    },
    {
      "id": "univ1081",
      "text": "このコンテンツはユニティちゃんライセンスで提供されています",
      "duration": 4.01
    },
    {
      "id": "univ1082",
      "text": "ユニティ・テクノロジーズ・ジャパンっ！",
      "duration": 1.954
    },
    {
      "id": "univ1083",
      "text": "ユニティ・テクノロジーズっ！",
      "duration": 1.594
    },
    {
      "id": "univ1084",
      "text": "パワード・バイ・ユニティっ！",
      "duration": 1.754
    },
    {
      "id": "univ1085",
      "text": "にゃーんっ！",
      "duration": 1.178
    },
    {
      "id": "univ1086",
      "text": "にゃにゃーんっ！",
      "duration": 1.455
    },
    {
      "id": "univ1087",
      "text": "じゃじゃ〜んっ！",
      "duration": 1.467
    },
    {
      "id": "univ1088",
      "text": "わたしと一緒に…ゲームしよっ？",
      "duration": 2.293
    },
    {
      "id": "univ1089",
      "text": "かわいく、撮ってねっ！",
      "duration": 1.641
    },
    {
      "id": "univ1090",
      "text": "時間ですよーっ！",
      "duration": 1.586
    },
    {
      "id": "univ1091",
      "text": "きゃっ！",
      "duration": 0.627
    },
    {
      "id": "univ1092",
      "text": "あんっ！",
      "duration": 0.535
    },
    {
      "id": "univ1093",
      "text": "あううっ…",
      "duration": 1.288
    },
    {
      "id": "univ1094",
      "text": "ひゃっ！",
      "duration": 0.675
    },
    {
      "id": "univ1095",
      "text": "ひっどぉーいっ！",
      "duration": 1.535
    },
    {
      "id": "univ1096",
      "text": "もう、怒ったぞおっ！",
      "duration": 2.123
    },
    {
      "id": "univ1097",
      "text": "ゲージいっぱいっ！",
      "duration": 1.399
    },
    {
      "id": "univ1098",
      "text": "ここから一気に逆転よっ！",
      "duration": 1.996
    },
    {
      "id": "univ1099",
      "text": "ドンマイ、ドンマイ…",
      "duration": 1.652
    },
    {
      "id": "univ1100",
      "text": "会心の一撃ぃっ！",
      "duration": 1.74
    },
    {
      "id": "univ1101",
      "text": "（氣を打ち込むイメージで）はっ！",
      "duration": 0.649
    },
    {
      "id": "univ1102",
      "text": "（氣を打ち込むイメージで）とおおおっ！",
      "duration": 1.403
    },
    {
      "id": "univ1103",
      "text": "これで終わりよっ！",
      "duration": 1.472
    },
    {
      "id": "univ1104",
      "text": "（可愛らしく）ファイナルブロウ、くらえっ！　やあっ！",
      "duration": 2.89
    },
    {
      "id": "univ1105",
      "text": "わたしでいいの…？",
      "duration": 1.681
    },
    {
      "id": "univ1106",
      "text": "選んでくれて、ありがとっ！",
      "duration": 1.93
    },
    {
      "id": "univ1107",
      "text": "さてさて、これからどうしよっか？",
      "duration": 2.949
    },
    {
      "id": "univ1108",
      "text": "なにして遊ぼうか？",
      "duration": 1.557
    },
    {
      "id": "univ1109",
      "text": "どれを選ぶ？",
      "duration": 1.327
    },
    {
      "id": "univ1110",
      "text": "今日はとっても楽しかった！　また一緒に遊ぼうねっ！",
      "duration": 4.02
    },
    {
      "id": "univ1111",
      "text": "ごめんね。なんかイマイチだった…",
      "duration": 3.091
    },
    {
      "id": "univ1112",
      "text": "う〜ん…今度は別の遊びをしようよっ！",
      "duration": 4.265
    },
    {
      "id": "univ1113",
      "text": "ねぇねぇ…今日、時間あるかな？",
      "duration": 2.676
    },
    {
      "id": "univ1114",
      "text": "ねぇねぇ…今、時間あるかな？",
      "duration": 2.422
    },
    {
      "id": "univ1115",
      "text": "（寂しそうに）わたしのとの約束…忘れちゃった？",
      "duration": 3.278
    },
    {
      "id": "univ1116",
      "text": "（ジェラシー含みの怒りっぽく）もぅっ、ばぁかぁーっ！",
      "duration": 2.738
    },
    {
      "id": "univ1117",
      "text": "わたしからのプレゼント…受け取ってくれるかな？",
      "duration": 3.821
    },
    {
      "id": "univ1118",
      "text": "えっ…そんな…それは恥ずかしくて言えないよ…",
      "duration": 4.642
    },
    {
      "id": "univ1119",
      "text": "一緒にいられるだけで、いいよ…",
      "duration": 2.411
    },
    {
      "id": "univ1120",
      "text": "これからもずっと一緒だよっ！",
      "duration": 2.329
    },
    {
      "id": "univ1121",
      "text": "むぅーっ！遅ぉーーーーいっ！",
      "duration": 2.483
    },
    {
      "id": "univ1122",
      "text": "今日のごはんはね〜…うふふっ！",
      "duration": 2.777
    },
    {
      "id": "univ1123",
      "text": "今日のお弁当はね〜…うふふっ！",
      "duration": 2.564
    },
    {
      "id": "univ1124",
      "text": "今日のおやつはね〜…うふふっ！",
      "duration": 2.588
    },
    {
      "id": "univ1125",
      "text": "これ、みーんな、アセットストアから落としてきたんだよっ！　すごいでしょーっ！　えへっ！",
      "duration": 5.519
    },
    {
      "id": "univ1126",
      "text": "大好きっ！",
      "duration": 1.005
    },
    {
      "id": "univ1127",
      "text": "（恥ずかしそうに）…好きだよ",
      "duration": 1.116
    },
    {
      "id": "univ1128",
      "text": "いい友達…かなっ？",
      "duration": 2.151
    },
    {
      "id": "univ1129",
      "text": "友達だよっ！",
      "duration": 1.152
    },
    {
      "id": "univ1130",
      "text": "うーん…ちょっと苦手かなぁ…",
      "duration": 3.016
    },
    {
      "id": "univ1131",
      "text": "（言いにくそうに）ごめん！嫌いなんだ…",
      "duration": 2.47
    },
    {
      "id": "univ1132",
      "text": "大っ嫌いっ！",
      "duration": 1.103
    },
    {
      "id": "univ1133",
      "text": "（可愛らしく）あなたが、あの伝説の生き別れのお父さんっ！？",
      "duration": 3.255
    },
    {
      "id": "univ1134",
      "text": "（可愛らしく）…なわけ、ないない",
      "duration": 2.113
    },
    {
      "id": "univ1135",
      "text": "（楽しげに）うふっ…そうこなくっちゃねっ！",
      "duration": 2.599
    },
    {
      "id": "univ1136",
      "text": "ゼロっ！",
      "duration": 0.768
    },
    {
      "id": "univ1137",
      "text": "ワンっ！",
      "duration": 0.626
    },
    {
      "id": "univ1138",
      "text": "ツー！",
      "duration": 0.677
    },
    {
      "id": "univ1139",
      "text": "スリー！",
      "duration": 0.809
    },
    {
      "id": "univ1140",
      "text": "フォー！",
      "duration": 0.699
    },
    {
      "id": "univ1141",
      "text": "ファイブっ！",
      "duration": 0.762
    },
    {
      "id": "univ1142",
      "text": "シックス！",
      "duration": 0.883
    },
    {
      "id": "univ1143",
      "text": "セブン！",
      "duration": 0.784
    },
    {
      "id": "univ1144",
      "text": "エイト！",
      "duration": 0.767
    },
    {
      "id": "univ1145",
      "text": "ナイン！",
      "duration": 0.771
    },
    {
      "id": "univ1146",
      "text": "テンっ！",
      "duration": 0.563
    },
    {
      "id": "univ1147",
      "text": "いち！",
      "duration": 0.703
    },
    {
      "id": "univ1148",
      "text": "にっ！",
      "duration": 0.621
    },
    {
      "id": "univ1149",
      "text": "さんっ！",
      "duration": 0.667
    },
    {
      "id": "univ1150",
      "text": "しっ！",
      "duration": 0.646
    },
    {
      "id": "univ1151",
      "text": "ごっ！",
      "duration": 0.663
    },
    {
      "id": "univ1152",
      "text": "ろくっ！",
      "duration": 0.751
    },
    {
      "id": "univ1153",
      "text": "ななっ！",
      "duration": 0.62
    },
    {
      "id": "univ1154",
      "text": "はちっ！",
      "duration": 0.736
    },
    {
      "id": "univ1155",
      "text": "きゅう！",
      "duration": 0.648
    },
    {
      "id": "univ1156",
      "text": "じゅうっ！",
      "duration": 0.773
    },
    {
      "id": "univ1157",
      "text": "ひとつ",
      "duration": 0.895
    },
    {
      "id": "univ1158",
      "text": "ふたつ",
      "duration": 0.906
    },
    {
      "id": "univ1159",
      "text": "みっつ",
      "duration": 0.804
    },
    {
      "id": "univ1160",
      "text": "よっつ",
      "duration": 0.872
    },
    {
      "id": "univ1161",
      "text": "いつつ",
      "duration": 0.836
    },
    {
      "id": "univ1162",
      "text": "むっつ",
      "duration": 0.872
    },
    {
      "id": "univ1163",
      "text": "ななつ",
      "duration": 0.956
    },
    {
      "id": "univ1164",
      "text": "やっつ",
      "duration": 0.8
    },
    {
      "id": "univ1165",
      "text": "ここのつ",
      "duration": 1.0
    },
    {
      "id": "univ1166",
      "text": "とお",
      "duration": 0.686
    },
    {
      "id": "univ1167",
      "text": "じゃんけん",
      "duration": 1.347
    },
    {
      "id": "univ1168",
      "text": "ぽんっ！",
      "duration": 0.525
    },
    {
      "id": "univ1169",
      "text": "グー！",
      "duration": 0.768
    },
    {
      "id": "univ1170",
      "text": "パー！",
      "duration": 0.646
    },
    {
      "id": "univ1171",
      "text": "チョキ！",
      "duration": 0.722
    },
    {
      "id": "univ1172",
      "text": "あいこで、しょっ！",
      "duration": 1.618
    },
    {
      "id": "univ1173",
      "text": "やったあ！　わたしの勝ちっ！",
      "duration": 2.409
    },
    {
      "id": "univ1174",
      "text": "うふふっ、あいこだねっ！",
      "duration": 1.942
    },
    {
      "id": "univ1175",
      "text": "残念。負けちゃった",
      "duration": 2.412
    },
    {
      "id": "univ1176",
      "text": "じゃんけん、ぽんっ！",
      "duration": 1.788
    },
    {
      "id": "univ1177",
      "text": "最初は、グーっ！",
      "duration": 1.829
    },
    {
      "id": "univ1178",
      "text": "あっち向いて…",
      "duration": 1.558
    },
    {
      "id": "univ1179",
      "text": "ほいっ！",
      "duration": 0.596
    },
    {
      "id": "univ1180",
      "text": "まるっ！",
      "duration": 0.711
    },
    {
      "id": "univ1181",
      "text": "バツっ！",
      "duration": 0.787
    },
    {
      "id": "univ1182",
      "text": "結果発表っ！じゃんじゃじゃーんっ！",
      "duration": 3.405
    },
    {
      "id": "univ1183",
      "text": "今回はがんばったね。おめでとう！",
      "duration": 2.757
    },
    {
      "id": "univ1184",
      "text": "今回はイマイチだったけど、次は頑張ろうねっ！",
      "duration": 3.4
    },
    {
      "id": "univ1185",
      "text": "今回は油断しちゃったかな？次はしっかりやろうねっ！",
      "duration": 4.218
    },
    {
      "id": "univ1186",
      "text": "レコード更新っ！おめでとうっ！",
      "duration": 2.888
    },
    {
      "id": "univ1187",
      "text": "スコア更新っ！おめでとうっ！",
      "duration": 2.414
    },
    {
      "id": "univ1188",
      "text": "ランキング更新っ！おめでとうっ！",
      "duration": 2.686
    },
    {
      "id": "univ1189",
      "text": "あらら〜…もっと頑張ろうねっ！",
      "duration": 2.995
    },
    {
      "id": "univ1190",
      "text": "大丈夫。あなたならきっと出来るよっ！",
      "duration": 3.145
    },
    {
      "id": "univ1191",
      "text": "わたし、応援しているからねっ！",
      "duration": 2.289
    },
    {
      "id": "univ1192",
      "text": "リラックス、リラックスっ！",
      "duration": 1.776
    },
    {
      "id": "univ1193",
      "text": "やったねっ！おめでとうっ！",
      "duration": 2.183
    },
    {
      "id": "univ1194",
      "text": "頑張ってる姿って、いいね。ステキだよ！",
      "duration": 3.043
    },
    {
      "id": "univ1195",
      "text": "上上下下左右左右ＢＡ（うえうえしたしたひだりみぎひだりみぎびーえー）で、おっけーだよっ！",
      "duration": 5.084
    },
    {
      "id": "univ1196",
      "text": "まったねぇ〜っ！バイバイ〜っ！",
      "duration": 2.312
    },
    {
      "id": "univ1198",
      "text": "もういいかい？",
      "duration": 1.843
    },
    {
      "id": "univ1199",
      "text": "まーだだよ",
      "duration": 1.897
    },
    {
      "id": "univ1200",
      "text": "もういいよっ！",
      "duration": 1.981
    },
    {
      "id": "univ1201",
      "text": "みーつけたっ！",
      "duration": 1.254
    },
    {
      "id": "univ1202",
      "text": "あらら、みつかっちゃった…",
      "duration": 2.156
    },
    {
      "id": "univ1203",
      "text": "えーと…ここかな？",
      "duration": 2.699
    },
    {
      "id": "univ1204",
      "text": "どこかなぁ？",
      "duration": 1.653
    },
    {
      "id": "univ1205",
      "text": "あれっ！？違う？",
      "duration": 1.633
    },
    {
      "id": "univ1206",
      "text": "また違った？",
      "duration": 1.561
    },
    {
      "id": "univ1207",
      "text": "わたしが鬼ねっ！",
      "duration": 1.456
    },
    {
      "id": "univ1208",
      "text": "あなたが鬼ねっ！",
      "duration": 1.331
    },
    {
      "id": "univ1209",
      "text": "待てーっ！",
      "duration": 1.434
    },
    {
      "id": "univ1210",
      "text": "待て待てーっ！",
      "duration": 1.701
    },
    {
      "id": "univ1211",
      "text": "えへっ！捕まえたっ！",
      "duration": 2.037
    },
    {
      "id": "univ1212",
      "text": "鬼さんこちらっ！",
      "duration": 2.109
    },
    {
      "id": "univ1213",
      "text": "こっちだよーっ！",
      "duration": 1.579
    },
    {
      "id": "univ1214",
      "text": "ほらほらっ！",
      "duration": 1.221
    },
    {
      "id": "univ1215",
      "text": "おっそーいっ！",
      "duration": 1.273
    },
    {
      "id": "univ1216",
      "text": "あれれっ…掴まっちゃった",
      "duration": 2.666
    },
    {
      "id": "univ1217",
      "text": "レッツ、ゴーっ！",
      "duration": 1.471
    },
    {
      "id": "univ1218",
      "text": "こはく、いっきまーすっ！",
      "duration": 2.221
    },
    {
      "id": "univ1219",
      "text": "はっしんっ！",
      "duration": 1.446
    },
    {
      "id": "univ1220",
      "text": "戦闘開始っ！",
      "duration": 1.51
    },
    {
      "id": "univ1221",
      "text": "ターゲット、ロックオンっ！",
      "duration": 1.696
    },
    {
      "id": "univ1222",
      "text": "ファイアッ！",
      "duration": 0.863
    },
    {
      "id": "univ1223",
      "text": "シューートッ！",
      "duration": 1.094
    },
    {
      "id": "univ1224",
      "text": "（冒頭タメて、）そんな攻撃が……わたしに効くかぁ〜〜っ！",
      "duration": 3.889
    },
    {
      "id": "univ1225",
      "text": "（コミカルに）退却〜っ！",
      "duration": 1.677
    },
    {
      "id": "univ1226",
      "text": "（コミカル）脱出しますぅ〜っ！",
      "duration": 2.017
    },
    {
      "id": "univ1227",
      "text": "いけぇーっ！",
      "duration": 1.442
    },
    {
      "id": "univ1228",
      "text": "うそっ！きゃあああっ！",
      "duration": 1.76
    },
    {
      "id": "univ1229",
      "text": "えーっ！弾切れっ！？",
      "duration": 1.995
    },
    {
      "id": "univ1230",
      "text": "まだまだっ！",
      "duration": 1.573
    },
    {
      "id": "univ1231",
      "text": "そろそろ、ヤバいかなぁ…",
      "duration": 1.813
    },
    {
      "id": "univ1232",
      "text": "パワーアップっ！",
      "duration": 1.303
    },
    {
      "id": "univ1233",
      "text": "私のターンだよっ！",
      "duration": 1.539
    },
    {
      "id": "univ1234",
      "text": "ドローっ！",
      "duration": 0.758
    },
    {
      "id": "univ1235",
      "text": "セット！",
      "duration": 0.802
    },
    {
      "id": "univ1236",
      "text": "ターンエンドっ！",
      "duration": 1.116
    },
    {
      "id": "univ1237",
      "text": "発動っ！",
      "duration": 0.908
    },
    {
      "id": "univ1238",
      "text": "あなたのターンだよっ！",
      "duration": 1.477
    },
    {
      "id": "univ1239",
      "text": "これで終わりっ！",
      "duration": 1.108
    },
    {
      "id": "univ1240",
      "text": "どれかな〜？　これかな〜？",
      "duration": 2.954
    },
    {
      "id": "univ1241",
      "text": "よろしくお願いしますっ！　えへへ…",
      "duration": 2.485
    },
    {
      "id": "univ1242",
      "text": "お手やわらかに、よろしくねっ！",
      "duration": 2.214
    },
    {
      "id": "univ1243",
      "text": "あちゃー…ダメかぁ…",
      "duration": 2.706
    },
    {
      "id": "univ1244",
      "text": "う〜ん…どうしよっかなぁ…",
      "duration": 2.883
    },
    {
      "id": "univ1245",
      "text": "ちょ、ちょっと！タンマっ！",
      "duration": 2.129
    },
    {
      "id": "univ1246",
      "text": "えーとぉ…やり直していい？",
      "duration": 3.697
    },
    {
      "id": "univ1247",
      "text": "（コミカルに）ふふん…ダメに決まっておろうがっ！",
      "duration": 3.347
    },
    {
      "id": "univ1248",
      "text": "我が邪気眼（じゃきがん）に逆らうとはな…",
      "duration": 2.416
    },
    {
      "id": "univ1249",
      "text": "あなたは…も、もしかして…我がマスターっ！？",
      "duration": 4.475
    },
    {
      "id": "univ1250",
      "text": "貴様を我がサーバントとして認めよう…ふふふっ！",
      "duration": 4.597
    },
    {
      "id": "univ1251",
      "text": "助けてっ！ユニティ仮面っ！",
      "duration": 2.541
    },
    {
      "id": "univ1252",
      "text": "わたしも戦うわっ！ユニティ仮面っ！",
      "duration": 2.409
    },
    {
      "id": "univ1253",
      "text": "みんなのパワーを、わたしにちょうだいっ！",
      "duration": 2.743
    },
    {
      "id": "univ1254",
      "text": "とぅ！",
      "duration": 0.523
    },
    {
      "id": "univ1255",
      "text": "とりゃ！",
      "duration": 0.883
    },
    {
      "id": "univ1256",
      "text": "てぇいっ！",
      "duration": 0.913
    },
    {
      "id": "univ1257",
      "text": "やぁあっ！",
      "duration": 0.744
    },
    {
      "id": "univ1258",
      "text": "（被ダメージ）痛たたたっ…！",
      "duration": 1.498
    },
    {
      "id": "univ1259",
      "text": "（被ダメージ）あうちっ！",
      "duration": 0.671
    },
    {
      "id": "univ1260",
      "text": "必殺っ！",
      "duration": 1.058
    },
    {
      "id": "univ1261",
      "text": "あちょーっ！",
      "duration": 1.212
    },
    {
      "id": "univ1262",
      "text": "ジャッジメントっ！",
      "duration": 1.209
    },
    {
      "id": "univ1263",
      "text": "正義は我にありっ！",
      "duration": 1.847
    },
    {
      "id": "univ1264",
      "text": "戦いの後は、熱々のカレーコロッケよね…はむっ！（と食べるアドリブ）はぁぁん…美味しい〜っ！",
      "duration": 9.687
    },
    {
      "id": "univ1265",
      "text": "（ダメージ後の荒い息づかい）…勝って…ユニティ仮面…わたしの代わりに勝ってね…ガクっ（と、うなだれる擬音を口で入れてください）",
      "duration": 9.437
    },
    {
      "id": "univ1266",
      "text": "（身体にエネルギーが満ちるイメージで）こっ…これが…これが…真の…ちからっ！",
      "duration": 5.208
    },
    {
      "id": "univ1267",
      "text": "あなたのパワー、あなたの意志、そしてあなたの夢と希望、全てこのわたしが受け取ったわっ！　ユニティ仮面っ！",
      "duration": 9.822
    },
    {
      "id": "univ1268",
      "text": "日付が変わったよ！",
      "duration": 1.602
    },
    {
      "id": "univ1269",
      "text": "１時！明日の準備は大丈夫？",
      "duration": 2.881
    },
    {
      "id": "univ1270",
      "text": "２時だよ〜…わたしもう寝るね〜…おやふみ…",
      "duration": 5.034
    },
    {
      "id": "univ1271",
      "text": "（寝息+）ふぁんじ…",
      "duration": 4.843
    },
    {
      "id": "univ1272",
      "text": "（寝息+）ひょじー…",
      "duration": 5.028
    },
    {
      "id": "univ1273",
      "text": "（寝息+）ほじ…",
      "duration": 4.971
    },
    {
      "id": "univ1274",
      "text": "（寝息+）ほふじ…",
      "duration": 5.213
    },
    {
      "id": "univ1275",
      "text": "７時かぁ…。ふわ〜ぁ…。おはよ〜",
      "duration": 5.297
    },
    {
      "id": "univ1276",
      "text": "８時だね。そろそろエンジンかけなきゃ",
      "duration": 3.92
    },
    {
      "id": "univ1277",
      "text": "９時だよ！遅刻してない？大丈夫？",
      "duration": 3.371
    },
    {
      "id": "univ1278",
      "text": "１０時〜",
      "duration": 1.228
    },
    {
      "id": "univ1279",
      "text": "１１時！もうすぐお昼！",
      "duration": 2.584
    },
    {
      "id": "univ1280",
      "text": "お昼だよ〜！",
      "duration": 1.273
    },
    {
      "id": "univ1281",
      "text": "１３時をお知らせしまーす",
      "duration": 2.088
    },
    {
      "id": "univ1282",
      "text": "１４時だね。一番マッタリしちゃう時間…",
      "duration": 3.956
    },
    {
      "id": "univ1283",
      "text": "１５時…。油断すると眠気が…",
      "duration": 4.565
    },
    {
      "id": "univ1284",
      "text": "じゅうろく…へへ、もう食べられない…よ…",
      "duration": 6.242
    },
    {
      "id": "univ1285",
      "text": "はっ！ 何時の間に１７時に！？",
      "duration": 2.864
    },
    {
      "id": "univ1286",
      "text": "もう１８時か〜。そろそろ暗くなってくるね",
      "duration": 4.275
    },
    {
      "id": "univ1287",
      "text": "１９時だよ。みんなテレビ見てる時間かな？",
      "duration": 3.794
    },
    {
      "id": "univ1288",
      "text": "２０時！ お仕事してる人はそろそろ一区切りかな？",
      "duration": 4.381
    },
    {
      "id": "univ1289",
      "text": "２１時〜。何か面白いテレビやってるかなぁ",
      "duration": 4.452
    },
    {
      "id": "univ1290",
      "text": "（風呂音+鼻歌交じり）ふんふ〜ん♪ ２２時だよーん♪",
      "duration": 5.0
    },
    {
      "id": "univ1291",
      "text": "ふい〜… あと一時間で今日も終わりだね〜",
      "duration": 4.331
    },
    {
      "id": "univ1292",
      "text": "０時です",
      "duration": 1.019
    },
    {
      "id": "univ1293",
      "text": "１時です",
      "duration": 1.012
    },
    {
      "id": "univ1294",
      "text": "２時になりました",
      "duration": 1.363
    },
    {
      "id": "univ1295",
      "text": "３時です",
      "duration": 1.016
    },
    {
      "id": "univ1296",
      "text": "４時です",
      "duration": 0.894
    },
    {
      "id": "univ1297",
      "text": "５時になりました",
      "duration": 1.363
    },
    {
      "id": "univ1298",
      "text": "６時です",
      "duration": 1.049
    },
    {
      "id": "univ1299",
      "text": "７時です",
      "duration": 1.05
    },
    {
      "id": "univ1300",
      "text": "８時になりました",
      "duration": 1.491
    },
    {
      "id": "univ1301",
      "text": "９時です",
      "duration": 0.854
    },
    {
      "id": "univ1302",
      "text": "１０時です",
      "duration": 0.944
    },
    {
      "id": "univ1303",
      "text": "１１時になりました",
      "duration": 1.698
    },
    {
      "id": "univ1304",
      "text": "１２時です",
      "duration": 1.213
    },
    {
      "id": "univ1305",
      "text": "１３時です",
      "duration": 1.26
    },
    {
      "id": "univ1306",
      "text": "１４時になりました",
      "duration": 1.684
    },
    {
      "id": "univ1307",
      "text": "１５時です",
      "duration": 1.189
    },
    {
      "id": "univ1308",
      "text": "１６時です",
      "duration": 1.253
    },
    {
      "id": "univ1309",
      "text": "１７時になりました",
      "duration": 1.754
    },
    {
      "id": "univ1310",
      "text": "１８時です",
      "duration": 1.477
    },
    {
      "id": "univ1311",
      "text": "１９時です",
      "duration": 1.17
    },
    {
      "id": "univ1312",
      "text": "２０時になりました",
      "duration": 1.626
    },
    {
      "id": "univ1313",
      "text": "２１時です",
      "duration": 1.44
    },
    {
      "id": "univ1314",
      "text": "２２時です",
      "duration": 1.325
    },
    {
      "id": "univ1315",
      "text": "２３時になりました",
      "duration": 1.86
    },
    {
      "id": "univ1316",
      "text": "明けましておめでとうございます。今年も精一杯がんばりますので、よろしくお願い致します。 …えへへ、たまにはね♪(イラスト出す)",
      "duration": 9.848
    },
    {
      "id": "univ1317",
      "text": "今日は成人の日だって！ 成人式とはまた違うのよね。成人の日とか成人式って、いざ迎えると何かが変わるものなのかなぁ…？",
      "duration": 11.317
    },
    {
      "id": "univ1318",
      "text": "ついに開戦の火蓋が斬って落とされた…。今日は節分ウォー。鬼という鬼を滅多斬りするデー…。あれ？ あ、そっか。滅多切りじゃなくて蜂の巣…ん？",
      "duration": 15.966
    },
    {
      "id": "univ1319",
      "text": "建国記念日だってさ！ この記念日って世界中何処に行ってもあるんだろうなぁ…。はっ！ ということは、建国が早い順に各国をめぐっていけばずっとお休み…。あ、今バカにしたでしょ！",
      "duration": 16.885
    },
    {
      "id": "univ1320",
      "text": "バレンタインデーだね！ ふっふっふ。今のわたしにかかればチョコの自作くらい造作も無い。というわけで、はいっ！ どうぞ！(イラスト出す)",
      "duration": 10.741
    },
    {
      "id": "univ1321",
      "text": "今日は雛祭りだよー。雛祭り…あまり良い思い出が無い…。パパってばわたしに重たい服着せたと思ったらかわいいかわいいしか言わなくなるし…。あ、でも雛壇にある菱形のお餅みたいなのは大好き！",
      "duration": 18.242
    },
    {
      "id": "univ1322",
      "text": "そわそわ。そわそわ。え？ な、何も？ 何でもないよ？",
      "duration": 7.668
    },
    {
      "id": "univ1323",
      "text": "ハールーっ！ 今日は春分の日だよ！ ",
      "duration": 4.336
    },
    {
      "id": "univ1324",
      "text": "今日はトーコちゃんの誕生日だよ。あとでミサキチ達とパーティするんだ！",
      "duration": 5.768
    },
    {
      "id": "univ1325",
      "text": "今日はミサキチの誕生日！ こないだトーコちゃんをお祝いしたばかりだけど、パーティは何度やってもオッケーだもんね♪",
      "duration": 8.576
    },
    {
      "id": "univ1326",
      "text": "なんと、今日は今月三回目の誕生パーティ。主役は茅野さんだよ。あんまり話す機会がないんだけど、あの人ってクールでかっこいいよね",
      "duration": 12.439
    },
    {
      "id": "univ1327",
      "text": "今日は憲法記念日…。これって記念日なの？",
      "duration": 4.874
    },
    {
      "id": "univ1328",
      "text": "今日はみどりの日だって。改めて思うけど、コーゲンシティにはあんまり緑が無いんだよね。その分青が多いんだ。あおの日とか作っちゃえばいいのにね",
      "duration": 13.17
    },
    {
      "id": "univ1329",
      "text": "今日はこどもの日！ 昔からわくわくする日だったな〜！ え？ ううん、そわそわなんてしてないよ？ ちょっと、子供っぽいって何ー！？",
      "duration": 12.919
    },
    {
      "id": "univ1330",
      "text": "今日はわたしのママの誕生日！ 学校から帰ったら家族みんなで一緒にご飯を作って、お祝いするんだ！",
      "duration": 7.889
    },
    {
      "id": "univ1331",
      "text": "今日は織姫と彦星の日だね。この街も川を挟んで三つの島に分かれてるから、川を挟んで恋愛してる人とかはきっと今日という日に想いを馳せ…え？ ううん、トーコちゃんが目をキラキラさせながら言ってたのを真似してみただけ。似てた？",
      "duration": 21.381
    },
    {
      "id": "univ1332",
      "text": "海の日っ！ 海…。あれ、何か忘れてるような…。あーっ！ ミサキチと水着買いに行く約束してたんだった！！(イラスト出す)",
      "duration": 12.671
    },
    {
      "id": "univ1333",
      "text": "ハッピーバースデーわたしー！ 今日はわたしの誕生日！ ふははは。わたしだってちゃんと成長しているのだよ〜？ 日々のご褒美も含めて何かプレゼントくれちゃってもいいのだよ〜？",
      "duration": 15.026
    },
    {
      "id": "univ1334",
      "text": "今日は敬老の日。この日になると急にパパがそわそわしだすのよね。まぁ、腰を踏んで肩を叩くくらいはしてあげるけど…",
      "duration": 10.103
    },
    {
      "id": "univ1335",
      "text": "味覚の秋！ 秋分の日だよ。 わたしの秋は味覚の秋なの！ でもこの街は本当に海しかないから、山に行こうものなら一大旅行なのよね。今年もスーパーで我慢するかぁ…",
      "duration": 16.524
    },
    {
      "id": "univ1336",
      "text": "今日はパパの誕生日。 なんだかんだで普段から拘りがあるから、お店で買えるプレゼントは喜んでくれないのよね…。え？ この紙？ 肩たたきけ…ううん、なんでもない！",
      "duration": 14.294
    },
    {
      "id": "univ1337",
      "text": "ついにきた、わたしの日！ 平たく言うと体育の日！ ふふふ、今日ははりきっちゃうぞー！(イラスト出す)",
      "duration": 8.842
    },
    {
      "id": "univ1338",
      "text": "ハァ…。文化の日のようです…。え？ テンション？ 低くない低くない。ハァ…。メイド喫茶とか…そんな安直な…ぶつぶつ。(イラスト出す)",
      "duration": 14.733
    },
    {
      "id": "univ1339",
      "text": "今日は勤労感謝デー。敬老の日と同じくパパのそわそわっぷりが鼻につくデーです。よくよく考えたらまだおじいちゃん生きてるし、何で敬老の日にパパを労ってたのかしらわたし…！！ 振り替え休日で今日は何もしないって言ったら…しばらく寝込みそうね…。しかたないなぁ",
      "duration": 22.943
    },
    {
      "id": "univ1340",
      "text": "クリスマス・イブ！ いやぁ…世の中デコデコですなぁ…。 そっちは雪降ってる？ こっちは今は止んでるけど、先月からすこーしずつ降り始めてるから、シーズン中は期待できるかもね！ あ〜スノボ行きたいな〜！",
      "duration": 17.78
    },
    {
      "id": "univ1341",
      "text": "メリークリスマース！ サンタこはくちゃんだぞー！ 良い子に開発を続けるみんなにプレゼントだ〜！ (イラスト出す)…うう、恥ずかしい。 いや違うんだよ〜！ これ、ミサキチが作ったんだけど、着ないと、えーと、大変なことするぞっていうから…。に、似合ってなくていいの！ ほらほら、サンタこはくちゃんはおしまい！ 七面鳥食べよ！ ね！",
      "duration": 31.286
    },
    {
      "id": "univ1342",
      "text": "ほへぇ…(炬燵の中で気抜け) あ、年の瀬だね…。 やっほー。 みかん食べる？ ふは〜… ふぇっ 寝てない、寝てないよ。 今日はちゃんと起きてないと勿体無いもんね〜。 あ〜お年玉楽しみだな〜。 あ、おせんべい食べる？",
      "duration": 23.569
    },
    {
      "id": "univ1343",
      "text": "お誕生日おめでとう！！ こはくちゃんから素敵なプレゼントをあげちゃうぞ！(イラスト出す) えへへ、また一歩成長しちゃったね！ 今年も一緒にがんばろー！",
      "duration": 11.621
    }
  ]
}
