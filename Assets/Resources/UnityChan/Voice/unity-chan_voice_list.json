    },
    {
      "id": "univ0029",
      "text": "きみの夢、一緒にかなえよう",
      "duration": 2.438
    },
    {
      "id": "univ0030",
      "text": "こんにちは。わたし《ユニティちゃん》",
      "duration": 2.664
    },
    {
      "id": "univ0031",
      "text": "もうすぐあなたに会えるよ",
      "duration": 2.02
    },
    {
      "id": "univ0032",
      "text": "さあ、あなたもはじめよう",
      "duration": 2.044
    },
    {
      "id": "univ0033",
      "text": "次は、あなたの番　だよ",
      "duration": 2.218
    },
    {
      "id": "univ0034",
      "text": "あなたの夢、一緒にかなえよう",
      "duration": 2.775
    },
    {
      "id": "univ0035",
      "text": "一緒に遊ぼうよ！",
      "duration": 1.765
    },
    {
      "id": "univ0036",
      "text": "一緒に遊ぼう！",
